[Unit]
Description=Plex Auto Subs — auto-sync and auto-translate subtitles on playback
After=plexmediaserver.service

[Service]
Type=simple
# ponytail: adjust User and WorkingDirectory to match your setup
User=plex
WorkingDirectory=/opt/plex-auto-subs
ExecStart=/usr/bin/python3 run_daemon.py
Restart=on-failure
RestartSec=10
Environment=PLEX_URL=http://localhost:32400
Environment=POLL_INTERVAL=15
Environment=TARGET_LANG=he
Environment=SOURCE_LANG=en

[Install]
WantedBy=multi-user.target
